---
import { Image } from 'astro:assets';
import laptopImg from '../assets/laptop.png';
---

<section id="inicio" class="hero-section relative pt-32 pb-24 overflow-hidden bg-nexo-dark-50">
  <!-- Subtle Background Grid -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#0D2E34 1px, transparent 1px); background-size: 40px 40px;"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="flex flex-col items-center text-center max-w-5xl mx-auto">
      
      <div class="hero-reveal overflow-hidden mb-6">
        <span class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-nexo-primary/10 text-nexo-primary text-[10px] font-bold tracking-[0.2em] uppercase border border-nexo-primary/20">
          <span class="w-1.5 h-1.5 rounded-full bg-nexo-primary animate-pulse"></span>
          Plataforma operativa para ISP
        </span>
      </div>
      
      <div class="hero-reveal overflow-hidden mb-8">
        <h1 class="text-6xl md:text-[5.5rem] font-extrabold text-nexo-dark leading-[0.95] tracking-tight">
          El Centro de Mando <br/>
          <span class="text-nexo-primary">de tu ISP.</span>
        </h1>
      </div>

      <div class="hero-reveal overflow-hidden mb-12">
        <p class="text-xl md:text-2xl text-nexo-dark/70 max-w-3xl leading-relaxed">
          Cuando clientes, cobros, red y soporte viven en sistemas distintos, la operación se frena. Nexo centraliza tu ISP en una sola plataforma — conectada a tu red vía API, sin rehacer toda la infraestructura.
        </p>
      </div>
      
      <div class="hero-reveal flex flex-col sm:flex-row items-center justify-center gap-6 mb-24 w-full">
        <a href="#contacto" class="group relative w-full sm:w-auto px-12 py-5 bg-nexo-dark text-white rounded-2xl font-bold text-lg overflow-hidden transition-all hover:shadow-2xl hover:shadow-nexo-dark/40 active:scale-95">
          <span class="relative z-10">Solicitar Demostración</span>
          <div class="absolute inset-0 bg-nexo-primary translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
        </a>
        <a href="#modulos" class="w-full sm:w-auto px-12 py-5 bg-white border border-nexo-dark/10 text-nexo-dark rounded-2xl font-bold text-lg hover:bg-nexo-dark-100 transition-colors active:scale-95">
          Explorar Ecosistema
        </a>
      </div>

      <!-- Dashboard Preview with Enhanced Framing -->
      <div class="hero-reveal-image relative w-full max-w-6xl">
        <div class="absolute -inset-4 bg-gradient-to-b from-nexo-primary/10 to-transparent rounded-[3.5rem] blur-2xl opacity-50"></div>
        <div class="relative bg-white p-3 md:p-5 rounded-[3rem] shadow-[0_50px_100px_-20px_rgba(13,46,52,0.15)] border border-nexo-dark-100 group transition-transform duration-700 hover:scale-[1.01]">
            <div class="absolute top-8 left-10 flex gap-2 z-20">
                <div class="w-2.5 h-2.5 rounded-full bg-nexo-dark/10"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-nexo-dark/10"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-nexo-dark/10"></div>
            </div>
            <div class="bg-nexo-dark-50 rounded-[2rem] overflow-hidden aspect-[16/9] relative">
                 <Image
                   src={laptopImg}
                   alt="Panel de control de Nexo en un portátil"
                   class="w-full h-full object-cover scale-105 group-hover:scale-100 transition-transform duration-1000"
                   loading="eager"
                 />
                 <div class="absolute inset-0 bg-gradient-to-t from-nexo-dark/80 via-nexo-dark/20 to-transparent flex items-end p-12">
                     <div class="text-left text-white max-w-md">
                         <div class="inline-block px-3 py-1 bg-nexo-primary text-nexo-dark text-[10px] font-black uppercase rounded-md mb-4">Centro de comando activo</div>
                         <h3 class="text-3xl font-bold mb-2">Una sola plataforma</h3>
                         <p class="text-white/70 text-sm">Facturación, pagos, red, soporte y monitoreo con más orden, visibilidad y control operativo.</p>
                     </div>
                 </div>
            </div>
        </div>
      </div>

    </div>
  </div>
</section>


