---
interface Props { id?: string; }
const { id } = Astro.props;

const permissionAreas = [
  { area: 'Widget barra', perms: 'Pago, Telegram, Notificaciones, Soporte.' },
  { area: 'Gestión de Red', perms: 'Router, IPv4, Monitoreo, NAP, Tráfico.' },
  { area: 'Servicios', perms: 'Internet, Voz, CATV, Personalizado.' },
  { area: 'Clientes', perms: 'Usuarios, Mapa, Anuncios, Instalaciones, Contratos.' },
  { area: 'Fichas Hotspot', perms: 'Fichas, Router, Plantillas, Ventas.' },
  { area: 'Tareas', perms: 'Nuevo, Editar, Eliminar.' },
  { area: 'Finanzas', perms: 'Facturas, Pagos, Transacciones, Reportes.' },
  { area: 'Almacén', perms: 'Categorías, Productos.' },
  { area: 'Reportes', perms: 'Administración.' },
  { area: 'Soporte', perms: 'Menu, Nuevo, Editar, Cerrar.' },
  { area: 'SMS', perms: 'Menu, Nuevo.' },
  { area: 'Ajustes', perms: 'General, Gestión, Facturación, Portal, Licencia.' },
];
---

<section id={id} class="doc-section mb-16">
  <div class="mb-6">
    <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-2 block">Sección 21</span>
    <h2 class="text-3xl md:text-4xl font-extrabold text-nexo-dark tracking-tight">Permisos y roles</h2>
  </div>

  <div class="space-y-6">
    <p class="text-nexo-dark/70 text-sm leading-relaxed">
      Cada operador tiene un <strong class="text-nexo-dark">rol</strong> con permisos. Definen qué ve en el menú y qué acciones puede ejecutar.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div class="doc-card !p-4 border-nexo-primary/30">
        <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-1.5 block">Administrador</span>
        <p class="text-nexo-dark/65 text-xs">Acceso total. Nivel 0.</p>
      </div>
      <div class="doc-card !p-4">
        <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-dark/40 mb-1.5 block">Operador</span>
        <p class="text-nexo-dark/65 text-xs">Solo lo que le asigne el administrador.</p>
      </div>
    </div>

    <div>
      <h3 class="text-lg font-bold text-nexo-dark mb-3">Áreas de permisos</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {permissionAreas.map(p => (
          <div class="bg-nexo-dark/[0.02] border border-nexo-dark/5 rounded-xl px-4 py-3">
            <p class="font-bold text-nexo-dark text-sm">{p.area}</p>
            <p class="text-nexo-dark/50 text-xs mt-1 leading-relaxed">{p.perms}</p>
          </div>
        ))}
      </div>
    </div>

    <div>
      <h3 class="text-lg font-bold text-nexo-dark mb-3">Solicitar acceso</h3>
      <div class="doc-card !py-4 !px-5">
        <ol class="space-y-2">
          <li class="flex items-start gap-2.5 text-sm text-nexo-dark/70"><span class="w-5 h-5 rounded-md bg-nexo-primary text-nexo-dark flex items-center justify-center text-[10px] font-bold shrink-0">1</span> Indique al admin el módulo que no ve.</li>
          <li class="flex items-start gap-2.5 text-sm text-nexo-dark/70"><span class="w-5 h-5 rounded-md bg-nexo-primary text-nexo-dark flex items-center justify-center text-[10px] font-bold shrink-0">2</span> Admin: <strong class="text-nexo-dark">Ajustes → Gestión personal → Permisos</strong>.</li>
          <li class="flex items-start gap-2.5 text-sm text-nexo-dark/70"><span class="w-5 h-5 rounded-md bg-nexo-primary text-nexo-dark flex items-center justify-center text-[10px] font-bold shrink-0">3</span> Active el permiso y cierre/abra sesión.</li>
        </ol>
      </div>
    </div>
  </div>
</section>
