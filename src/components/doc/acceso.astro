---
interface Props { id?: string; }
const { id } = Astro.props;

const loginSteps = [
  'Abra el navegador e ingrese la URL: https://su-servidor/admin/',
  'Ingrese usuario y contraseña (y código 2FA si está activo).',
  'Presione Iniciar sesión → será redirigido al Dashboard.',
];

const problems = [
  { problem: 'Usuario o contraseña incorrectos', solution: 'Revise mayúsculas/minúsculas. Si persiste, pida restablecer credenciales al administrador.' },
  { problem: 'Sesión expirada', solution: 'Vuelva a iniciar sesión. Se cierra sola tras inactividad.' },
  { problem: 'No veo ciertos módulos', solution: 'Su rol no tiene esos permisos. Solicítelos al administrador.' },
];

const sessionActions = [
  {
    title: 'Cerrar sesión',
    steps: ['Avatar (arriba a la derecha)', 'Cerrar Sesión', 'Vuelve a la pantalla de login'],
  },
  {
    title: 'Cambiar contraseña',
    steps: ['Avatar → Cambiar Contraseña', 'Contraseña actual + nueva (dos veces)', 'Guardar'],
  },
];
---

<section id={id} class="doc-section mb-16">
  <div class="mb-6">
    <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-2 block">Sección 3</span>
    <h2 class="text-3xl md:text-4xl font-extrabold text-nexo-dark tracking-tight">Acceso al sistema</h2>
  </div>

  <div class="space-y-8">
    <div>
      <h3 class="text-lg font-bold text-nexo-dark mb-4">Iniciar sesión</h3>
      <div class="doc-card !py-4 !px-5">
        <ol class="space-y-2.5">
          {loginSteps.map((step, i) => (
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-lg bg-nexo-primary text-nexo-dark flex items-center justify-center text-xs font-bold shrink-0">{i + 1}</span>
              <span class="text-nexo-dark/70 text-sm leading-relaxed pt-0.5">{step}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <div>
      <h3 class="text-lg font-bold text-nexo-dark mb-4">Problemas comunes</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        {problems.map(p => (
          <div class="doc-card !p-4">
            <div class="flex items-start gap-3">
              <div class="w-7 h-7 rounded-lg bg-red-50 text-red-500 flex items-center justify-center shrink-0">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path></svg>
              </div>
              <div class="min-w-0">
                <p class="font-bold text-nexo-dark text-sm leading-snug">{p.problem}</p>
                <p class="text-nexo-dark/55 text-xs mt-1.5 leading-relaxed">{p.solution}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div>
      <h3 class="text-lg font-bold text-nexo-dark mb-4">Sesión y cuenta</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {sessionActions.map(block => (
          <div class="doc-card !p-4">
            <p class="font-bold text-nexo-dark text-sm mb-3">{block.title}</p>
            <ol class="space-y-2">
              {block.steps.map((step, i) => (
                <li class="flex items-start gap-2.5">
                  <span class="w-5 h-5 rounded-md bg-nexo-primary text-nexo-dark flex items-center justify-center text-[10px] font-bold shrink-0">{i + 1}</span>
                  <span class="text-nexo-dark/65 text-xs leading-relaxed pt-0.5">{step}</span>
                </li>
              ))}
            </ol>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
