---
import DocImage from './DocImage.astro';
import imgCajasNap from '../../assets/img-docs/doc-01.png';
import imgMonitoreo from '../../assets/img-docs/doc-02.png';
import imgTrafico from '../../assets/img-docs/doc-03.png';
import imgRouters from '../../assets/img-docs/doc-05.png';
import imgSmartOlt from '../../assets/img-docs/doc-08.png';
import imgAdminOlt from '../../assets/img-docs/doc-18.png';
import imgRedes from '../../assets/img-docs/doc-19.png';
import imgIpsVisitadas from '../../assets/img-docs/doc-26.png';
import imgBlackList from '../../assets/img-docs/doc-16.png';

interface Props { id?: string; }
const { id } = Astro.props;

const primary = [
  {
    title: 'Routers',
    what: 'Equipos MikroTik del ISP: conexión API, configuración, monitoreo y backups.',
    steps: [
      'Nuevo → nombre (ej. “Nodo Centro”), IP del MikroTik, credenciales API y GPS opcional → Guardar.',
      'En la lista verá el estado conectado/desconectado.',
    ],
    tabs: ['Datos & Config', 'Bloqueo de páginas', 'Mikrotik', 'Gráficos', 'Log', 'Backups'],
    images: [{ src: imgRouters, alt: 'Lista de routers MikroTik', caption: 'Listado con estado de conexión API.' }],
  },
  {
    title: 'Smart OLT / AdminOLT',
    what: 'OLT de fibra: ONUs, señal y perfiles de velocidad. El panel general lista ONUs; la autorización de una ONU nueva se hace desde la ficha del cliente.',
    steps: [
      'Revise ONUs registradas en Gestión de Red → AdminOLT o Smart OLT.',
      'Para autorizar una nueva: ficha del cliente → Servicios → AdminOLT/SmartOLT.',
      'Elija la ONU pendiente (no autorizada) → Autorizar → configure WAN si aplica → Guardar.',
      'La ONU queda activa en la OLT y el servicio se habilita.',
    ],
    images: [
      { src: imgSmartOlt, alt: 'Panel Smart OLT', caption: 'ONUs online/offline y señal RX.' },
      { src: imgAdminOlt, alt: 'Panel AdminOLT', caption: 'VLAN, Zonas y Profiles.' },
    ],
  },
  {
    title: 'Cajas NAP',
    what: 'Cajas de fibra en calle: ubicación, capacidad de puertos y clientes conectados.',
    steps: [
      'Nuevo → nombre, dirección/coordenadas y capacidad de puertos → Guardar.',
      'Al dar de alta fibra, asigne el puerto NAP en la ficha del servicio.',
    ],
    images: [{ src: imgCajasNap, alt: 'Cajas NAP', caption: 'Ubicación y estado de puertos.' }],
  },
];

const secondary = [
  {
    title: 'Redes (IPv4 / IPv6)',
    what: 'Pools y subredes: rango, router asociado, IPs usadas vs disponibles. La IP al cliente se asigna al crear o editar el servicio en su ficha.',
    image: { src: imgRedes, alt: 'Pools IP', caption: 'Pools con uso y router.' },
  },
  {
    title: 'Monitoreo (Emisores)',
    what: 'Emisores e inalámbricos: online/offline. Al abrir un emisor verá señal, clientes conectados y uptime.',
    image: { src: imgMonitoreo, alt: 'Monitoreo de emisores', caption: 'Estado por emisor.' },
  },
  {
    title: 'Tráfico',
    what: 'Ancho de banda por router o cliente. Seleccione equipo/cliente, rango de fechas, revise subida/bajada y exporte a Excel o PDF si necesita.',
    image: { src: imgTrafico, alt: 'Tráfico', caption: 'Filtros por router y fechas.' },
  },
  {
    title: 'IPs Visitadas',
    what: 'Destinos o sitios que visitan los clientes. Requiere logging activo en el router.',
    image: { src: imgIpsVisitadas, alt: 'IPs visitadas', caption: 'Destinos por cliente.' },
  },
  {
    title: 'Monitor BlackList',
    what: 'IPs o dominios bloqueados en la red y su estado.',
    image: { src: imgBlackList, alt: 'BlackList', caption: 'IPs bloqueadas.' },
  },
];
---

<section id={id} class="doc-section mb-16">
  <div class="mb-6">
    <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-2 block">Sección 6</span>
    <h2 class="text-3xl md:text-4xl font-extrabold text-nexo-dark tracking-tight">Gestión de Red</h2>
    <p class="text-nexo-dark/50 text-sm mt-2">Infraestructura del ISP: routers, OLT, NAP, pools IP y monitoreo.</p>
  </div>

  <div class="space-y-8">
    {primary.map(sub => (
      <div>
        <h3 class="text-lg font-bold text-nexo-dark mb-1">{sub.title}</h3>
        <p class="text-nexo-dark/60 text-sm mb-3">{sub.what}</p>
        {sub.images.length > 1 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-3">
            {sub.images.map(img => (
              <DocImage src={img.src} alt={img.alt} caption={img.caption} />
            ))}
          </div>
        ) : (
          sub.images.map(img => (
            <DocImage src={img.src} alt={img.alt} caption={img.caption} />
          ))
        )}
        {sub.tabs && (
          <div class="flex flex-wrap gap-1.5 mb-3">
            {sub.tabs.map(tab => (
              <span class="px-2.5 py-1 bg-nexo-dark/5 border border-nexo-dark/10 rounded-md text-[11px] font-semibold text-nexo-dark/60">{tab}</span>
            ))}
          </div>
        )}
        <div class="doc-card !py-4 !px-5">
          <ol class="space-y-2">
            {sub.steps.map((step, i) => (
              <li class="flex items-start gap-2.5 text-sm text-nexo-dark/70">
                <span class="w-5 h-5 rounded-md bg-nexo-primary text-nexo-dark flex items-center justify-center text-[10px] font-bold shrink-0">{i + 1}</span>
                {step}
              </li>
            ))}
          </ol>
        </div>
      </div>
    ))}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {secondary.map(sub => (
        <div>
          <h3 class="text-base font-bold text-nexo-dark mb-1">{sub.title}</h3>
          <p class="text-nexo-dark/60 text-xs mb-2 leading-relaxed">{sub.what}</p>
          <DocImage src={sub.image.src} alt={sub.image.alt} caption={sub.image.caption} />
        </div>
      ))}
    </div>
  </div>
</section>
