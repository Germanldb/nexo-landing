---
interface Props { id?: string; }
const { id } = Astro.props;

const faqGroups = [
  {
    category: 'General',
    questions: [
      {
        q: '¿Por qué no veo un módulo en el menú?',
        a: 'Su rol no tiene permiso para ese módulo. Pida al administrador que lo asigne en Ajustes → Gestión personal.',
      },
      {
        q: '¿Puedo usar Nexo desde el celular?',
        a: 'Sí, el panel funciona desde el navegador del celular. Para tareas complejas (alta de clientes, facturación, red) conviene escritorio.',
      },
      {
        q: '¿Cómo busco un cliente rápidamente?',
        a: 'Buscador de la barra superior: al menos 3 caracteres de nombre, cédula o código, y seleccione de la lista.',
      },
    ],
  },
  {
    category: 'Facturación',
    questions: [
      {
        q: '¿Cómo genero una factura manual?',
        a: 'Ficha del cliente → Facturación → Nueva factura. O espere la generación automática del cron según la configuración de facturación.',
      },
      {
        q: 'El cliente pagó pero sigue suspendido.',
        a: 'Verifique que el pago se aplicó a la factura correcta y cubre el monto. Revise Finanzas → Transacciones.',
      },
      {
        q: '¿Cómo anulo una factura?',
        a: 'Finanzas → Facturas → ubique la factura → Anular. Requiere permiso de anular facturas.',
      },
    ],
  },
  {
    category: 'Red',
    questions: [
      {
        q: 'Un cliente no tiene internet pero aparece activo en Nexo.',
        a: 'Revise: 1) estado en el router, 2) ONU autorizada en la OLT, 3) colas MikroTik activas, 4) que no haya corte por mora.',
      },
      {
        q: '¿Cómo reinicio la ONU de un cliente?',
        a: 'Ficha → Servicios → AdminOLT/SmartOLT → Reiniciar ONT.',
      },
    ],
  },
  {
    category: 'Hotspot',
    questions: [
      {
        q: '¿Cómo vendo una ficha hotspot?',
        a: 'Fichas Hotspot → Fichas → Nuevo lote → Imprimir y entregar. Se marca vendida al usarse o de forma manual.',
      },
    ],
  },
  {
    category: 'Soporte',
    questions: [
      {
        q: '¿El cliente puede ver las notas internas de un ticket?',
        a: 'No. Las notas internas solo las ve el ISP. El cliente solo ve las respuestas públicas.',
      },
    ],
  },
];
---

<section id={id} class="doc-section mb-16">
  <div class="mb-6">
    <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-2 block">Sección 22</span>
    <h2 class="text-3xl md:text-4xl font-extrabold text-nexo-dark tracking-tight">Preguntas frecuentes</h2>
  </div>

  <div class="space-y-8">
    {faqGroups.map(group => (
      <div>
        <h3 class="text-base font-bold text-nexo-dark mb-3">{group.category}</h3>
        <div class="space-y-2">
          {group.questions.map(qa => (
            <details class="group bg-nexo-dark/[0.02] border border-nexo-dark/5 rounded-xl overflow-hidden hover:border-nexo-primary/20 transition-colors">
              <summary class="flex justify-between items-center gap-3 px-4 py-3 cursor-pointer list-none font-semibold text-nexo-dark text-sm">
                {qa.q}
                <div class="w-7 h-7 rounded-lg bg-nexo-dark/5 flex items-center justify-center transition-all duration-300 group-open:rotate-180 group-open:bg-nexo-primary group-open:text-nexo-dark shrink-0">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path></svg>
                </div>
              </summary>
              <div class="px-4 pb-3 text-nexo-dark/60 text-sm leading-relaxed">
                {qa.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
