---
interface Props { id?: string; }
const { id } = Astro.props;

const terms = [
  { term: 'Cliente / Usuario', desc: 'Persona o empresa que contrata los servicios de internet del ISP.' },
  { term: 'Servicio', desc: 'Conexión activa (Internet, Voz, CATV, IPTV) asociada a un cliente específico.' },
  { term: 'Perfil', desc: 'Plan de servicio que define velocidad, precio y reglas de facturación.' },
  { term: 'Router / Nodo', desc: 'Equipo MikroTik que gestiona la conexión de los clientes en una zona.' },
  { term: 'OLT', desc: 'Equipo de fibra óptica (AdminOLT o SmartOLT) que controla las ONUs de los clientes.' },
  { term: 'ONU / ONT', desc: 'Equipo de fibra óptica instalado en el hogar del cliente.' },
  { term: 'NAP', desc: 'Caja de distribución de fibra en la calle que conecta múltiples clientes.' },
  { term: 'Radius', desc: 'Servidor de autenticación que valida el acceso de usuarios a la red.' },
  { term: 'Corte', desc: 'Suspensión automática del servicio cuando el cliente no paga a tiempo.' },
  { term: 'Prepago', desc: 'El cliente paga antes de usar el servicio durante el periodo.' },
  { term: 'Postpago', desc: 'El cliente usa el servicio y paga al final del periodo.' },
  { term: 'Ficha Hotspot', desc: 'Ticket de acceso temporal a WiFi con PIN y usuario generados.' },
  { term: 'Pasarela', desc: 'Integración con banco o procesador de pagos en línea.' },
  { term: 'Sucursal', desc: 'Sede o punto de operación del ISP (puede tener varias).' },
  { term: 'Ticket', desc: 'Solicitud de soporte técnico que un cliente abre o un operador crea.' },
];
---

<section id={id} class="doc-section mb-20">
  <div class="mb-10">
    <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-3 block">Sección 2</span>
    <h2 class="text-3xl md:text-4xl font-extrabold text-nexo-dark tracking-tight">Conceptos básicos y glosario</h2>
    <p class="text-nexo-dark/50 text-lg mt-4">Antes de empezar, familiarícese con los términos clave que usará en Nexo.</p>
  </div>

  <div class="doc-card overflow-hidden p-0">
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead>
          <tr class="bg-nexo-dark/[0.03]">
            <th class="px-6 py-4 text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-dark/60 w-1/3">Término</th>
            <th class="px-6 py-4 text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-dark/60">Significado</th>
          </tr>
        </thead>
        <tbody>
          {terms.map((t, i) => (
            <tr class:list={['border-t border-nexo-dark/5', i % 2 === 0 ? 'bg-white' : 'bg-nexo-dark/[0.015]']}>
              <td class="px-6 py-4 font-bold text-nexo-dark text-sm">{t.term}</td>
              <td class="px-6 py-4 text-nexo-dark/70 text-sm leading-relaxed">{t.desc}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
