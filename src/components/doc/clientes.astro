---
import DocImage from './DocImage.astro';
import imgUsuarios from '../../assets/img-docs/doc-14.png';
import imgMapa from '../../assets/img-docs/doc-17.png';
import imgAnuncios from '../../assets/img-docs/doc-29.png';
import imgPush from '../../assets/img-docs/doc-22.png';
import imgInstalaciones from '../../assets/img-docs/doc-20.png';
import imgContratos from '../../assets/img-docs/doc-12.png';
import imgCorreos from '../../assets/img-docs/doc-13.png';

interface Props { id?: string; }
const { id } = Astro.props;

const wizardSteps = [
  {
    num: 1,
    title: 'Datos personales',
    fields: ['Nombre o razón social', 'Cédula / RIF (validación por país)', 'Dirección, teléfono, email', 'GPS opcional'],
  },
  {
    num: 2,
    title: 'Facturación',
    fields: ['Prepago o postpago', 'Día de pago (1–28) y día de corte', 'Avisos SMS / email / push', 'Configuración de mora'],
  },
  {
    num: 3,
    title: 'Servicios',
    fields: ['Router/nodo y perfil', 'Tipo de conexión (PPPoE, Hotspot…)', 'IP automática o estática / IPv6', 'Ubicación / NAP si es fibra'],
  },
];

const toolButtons = [
  { btn: 'Nuevo', desc: 'Alta de cliente' },
  { btn: 'Filtrar', desc: 'Filtro avanzado colapsable' },
  { btn: 'Estado', desc: 'Todos / Activos / Suspendidos / Retirados / Online' },
  { btn: 'Suspender', desc: 'Suspender selección (permiso Activar)' },
  { btn: 'Activar', desc: 'Activar selección' },
  { btn: 'Retirar', desc: 'Retirar selección' },
  { btn: 'Eliminar', desc: 'Eliminar selección' },
];

const withSteps = [
  {
    title: 'Mapa de Clientes',
    what: 'Ubicación geográfica de los abonados. Requiere coordenadas GPS en las fichas.',
    steps: [
      'El mapa muestra un marcador por cliente; clic para ver datos básicos.',
      'Filtre por activos, suspendidos u otros estados.',
    ],
    image: { src: imgMapa, alt: 'Mapa de clientes', caption: 'Ubicación GPS y filtros por estado.' },
  },
  {
    title: 'Anuncios',
    what: 'Avisos visibles en el portal: mantenimientos, promociones, comunicados oficiales.',
    steps: [
      'Nuevo → título y contenido.',
      'Vigencia (inicio/fin) y alcance: todos los clientes o un grupo → publique.',
    ],
    image: { src: imgAnuncios, alt: 'Anuncios del portal', caption: 'Avisos visibles para abonados.' },
  },
  {
    title: 'Instalaciones',
    what: 'Ciclo completo: pre-registro de prospectos, orden, materiales y alta del cliente.',
    steps: [
      'Registro → Nuevo: cédula, nombre, teléfono, dirección y plan → Pendiente.',
      'En Instalaciones → Aceptar instalación: asigne técnico y fecha.',
      'Materiales: productos del almacén (ONU, cable…). El inventario se descuenta solo.',
      'Imprimir genera PDF con datos, materiales y plan.',
      'Dar de alta abre el wizard de usuarios con datos precargados.',
    ],
    image: { src: imgInstalaciones, alt: 'Instalaciones', caption: 'Pre-registro de prospectos.' },
  },
  {
    title: 'Contratos',
    what: 'Contratos formales en PDF desde Clientes → Contratos o desde la ficha.',
    steps: [
      'Nuevo contrato → elija plantilla → revise datos precargados.',
      'Genere PDF y envíelo por correo o imprímalo para firma física.',
    ],
    image: { src: imgContratos, alt: 'Contratos', caption: 'Resumen por estado.' },
  },
];

const simple = [
  { title: 'Notificaciones Push', what: 'Envío push a la app móvil o al navegador del cliente.', image: { src: imgPush, alt: 'Push', caption: 'Envío a dispositivos.' } },
  { title: 'Correos', what: 'Bandeja de facturas, avisos y respuestas relacionados con clientes.', image: { src: imgCorreos, alt: 'Correos', caption: 'Historial de comunicaciones.' } },
];
---

<section id={id} class="doc-section mb-16">
  <div class="mb-6">
    <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-2 block">Sección 9</span>
    <h2 class="text-3xl md:text-4xl font-extrabold text-nexo-dark tracking-tight">Clientes</h2>
    <p class="text-nexo-dark/50 text-sm mt-2">Ciclo de vida del abonado: listado, alta, instalaciones, contratos y comunicaciones.</p>
  </div>

  <div class="space-y-8">
    <div>
      <h3 class="text-lg font-bold text-nexo-dark mb-1">Usuarios</h3>
      <p class="text-nexo-dark/60 text-sm mb-3">Listar, buscar, filtrar y actuar sobre la selección actual.</p>
      <DocImage
        src={imgUsuarios}
        alt="Listado de usuarios clientes"
        caption="Listado con deuda, estado y acciones masivas."
      />
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-5">
        {toolButtons.map(b => (
          <div class="bg-nexo-dark/[0.02] border border-nexo-dark/5 rounded-lg px-3 py-2">
            <p class="font-bold text-nexo-dark text-xs">{b.btn}</p>
            <p class="text-nexo-dark/50 text-[11px] leading-snug">{b.desc}</p>
          </div>
        ))}
      </div>

      <h4 class="text-base font-bold text-nexo-dark mb-2">Alta de cliente (wizard 3 pasos)</h4>
      <p class="text-nexo-dark/55 text-xs mb-3">Si viene de una instalación, use Dar de alta en Instalaciones para precargar datos.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        {wizardSteps.map(step => (
          <div class="doc-card !py-3 !px-4">
            <div class="flex items-center gap-2 mb-2">
              <span class="w-6 h-6 rounded-lg bg-nexo-primary text-nexo-dark flex items-center justify-center text-xs font-bold">{step.num}</span>
              <p class="font-bold text-nexo-dark text-sm">{step.title}</p>
            </div>
            <ul class="space-y-1">
              {step.fields.map(f => (
                <li class="flex items-start gap-1.5 text-[11px] text-nexo-dark/60">
                  <span class="w-1 h-1 rounded-full bg-nexo-primary mt-1.5 shrink-0"></span>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    {withSteps.map(sub => (
      <div>
        <h3 class="text-lg font-bold text-nexo-dark mb-1">{sub.title}</h3>
        <p class="text-nexo-dark/60 text-sm mb-3">{sub.what}</p>
        <DocImage src={sub.image.src} alt={sub.image.alt} caption={sub.image.caption} />
        <div class="doc-card !py-4 !px-5">
          <ol class="space-y-2">
            {sub.steps.map((step, i) => (
              <li class="flex items-start gap-2.5 text-sm text-nexo-dark/70">
                <span class="w-5 h-5 rounded-md bg-nexo-primary text-nexo-dark flex items-center justify-center text-[10px] font-bold shrink-0">{i + 1}</span>
                {step}
              </li>
            ))}
          </ol>
        </div>
      </div>
    ))}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {simple.map(sub => (
        <div>
          <h3 class="text-base font-bold text-nexo-dark mb-1">{sub.title}</h3>
          <p class="text-nexo-dark/55 text-xs mb-2">{sub.what}</p>
          <DocImage src={sub.image.src} alt={sub.image.alt} caption={sub.image.caption} />
        </div>
      ))}
    </div>
  </div>
</section>
