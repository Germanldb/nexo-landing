---
import DocImage from './DocImage.astro';
import imgBarra from '../../assets/img-docs/doc-55.png';
import imgMenuUsuario from '../../assets/img-docs/doc-56.png';

interface Props { id?: string; }
const { id } = Astro.props;

const features = [
  {
    icon: '🔍',
    title: 'Buscar cliente',
    desc: 'Escriba ≥3 caracteres (nombre, cédula o código) y abra la ficha desde la lista.',
  },
  {
    icon: '💲',
    title: 'Pago rápido',
    desc: 'El icono $ abre Registrar Pagos directo. Requiere widget de pago activo.',
  },
  {
    icon: '🔔',
    title: 'Notificaciones',
    desc: 'Campana: pagos, tickets y avisos. Clic para ver detalle y marcar como leídas.',
  },
  {
    icon: '🌙',
    title: 'Tema',
    desc: 'Alterna claro/oscuro (luna/sol). Colores de acento desde configuración.',
  },
];

const userMenu = [
  { option: 'Asistencia', desc: 'Registro de asistencia' },
  { option: 'Mi Perfil', desc: 'Datos del operador' },
  { option: 'Cambiar Contraseña', desc: 'Actualizar acceso' },
  { option: 'Cerrar Sesión', desc: 'Salir del sistema' },
];
---

<section id={id} class="doc-section mb-16">
  <div class="mb-6">
    <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-2 block">Sección 4</span>
    <h2 class="text-3xl md:text-4xl font-extrabold text-nexo-dark tracking-tight">Barra superior</h2>
    <p class="text-nexo-dark/50 text-sm mt-2">Accesos rápidos siempre visibles.</p>
  </div>

  <div class="space-y-8">
    <DocImage
      src={imgBarra}
      alt="Barra superior de Nexo con buscador e iconos de acceso rápido"
      caption="Barra superior: logo, buscar cliente e iconos de acciones."
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-3">
      {features.map(f => (
        <div class="doc-card !p-4">
          <div class="text-xl mb-2">{f.icon}</div>
          <h3 class="font-bold text-nexo-dark text-sm mb-1.5">{f.title}</h3>
          <p class="text-nexo-dark/55 text-xs leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>

    <div>
      <h3 class="text-lg font-bold text-nexo-dark mb-4">Menú de usuario</h3>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 items-start">
        <DocImage
          src={imgMenuUsuario}
          alt="Menú desplegable del avatar de usuario en Nexo"
          caption="Clic en el avatar: Asistencia, Perfil, Contraseña y Cerrar sesión."
        />
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-3">
          {userMenu.map(item => (
            <div class="flex items-center gap-3 bg-nexo-dark/[0.02] border border-nexo-dark/5 rounded-xl px-4 py-3">
              <span class="w-1.5 h-1.5 rounded-full bg-nexo-primary shrink-0"></span>
              <div class="min-w-0">
                <p class="font-bold text-nexo-dark text-sm">{item.option}</p>
                <p class="text-nexo-dark/50 text-xs">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
