---
interface Props { id?: string; }
const { id } = Astro.props;

const features = [
  {
    icon: '🔍',
    title: 'Buscar cliente',
    desc: 'El acceso más rápido para atender a un cliente. Escriba al menos 3 caracteres del nombre, cédula o código y seleccione de la lista desplegable. Se abrirá directamente su ficha.',
    tip: 'Este es el acceso más rápido para atender a un cliente en mostrador o por teléfono.',
  },
  {
    icon: '💲',
    title: 'Registrar pago rápido',
    desc: 'El icono de dólar ($) en la barra redirige directamente al módulo de Registrar Pagos sin pasar por el menú lateral. Ideal para caja.',
    permission: 'Widget de pago activo.',
  },
  {
    icon: '🔔',
    title: 'Notificaciones',
    desc: 'El icono de campana muestra alertas del sistema: pagos recibidos, tickets pendientes, avisos de red, etc. Haga clic para ver el detalle y marcar como leídas.',
  },
  {
    icon: '🌙',
    title: 'Modo oscuro y personalización',
    desc: 'Alterne entre tema claro y oscuro con el botón luna/sol. También puede personalizar los colores de acento del panel desde el panel de configuración.',
  },
];

const userMenu = [
  { option: 'Asistencia', desc: 'Registro de asistencia del operador' },
  { option: 'Mi Perfil', desc: 'Datos del operador logueado' },
  { option: 'Cambiar Contraseña', desc: 'Actualizar credenciales de acceso' },
  { option: 'Cerrar Sesión', desc: 'Salir del sistema' },
];
---

<section id={id} class="doc-section mb-20">
  <div class="mb-10">
    <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-3 block">Sección 4</span>
    <h2 class="text-3xl md:text-4xl font-extrabold text-nexo-dark tracking-tight">Barra superior</h2>
    <p class="text-nexo-dark/50 text-lg mt-4">La barra superior está siempre visible y ofrece accesos rápidos a las funciones más usadas.</p>
  </div>

  <div class="space-y-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {features.map(f => (
        <div class="doc-card">
          <div class="text-2xl mb-4">{f.icon}</div>
          <h3 class="font-bold text-nexo-dark mb-2">{f.title}</h3>
          <p class="text-nexo-dark/60 text-sm leading-relaxed">{f.desc}</p>
          {f.tip && (
            <div class="mt-4 bg-nexo-primary/10 border border-nexo-primary/30 rounded-xl px-4 py-3 text-sm text-nexo-dark/70">
              <strong class="text-nexo-dark">Consejo:</strong> {f.tip}
            </div>
          )}
          {f.permission && (
            <p class="mt-3 text-xs text-nexo-dark/40">Permiso requerido: {f.permission}</p>
          )}
        </div>
      ))}
    </div>

    <div>
      <h3 class="text-xl font-bold text-nexo-dark mb-6">Menú de usuario</h3>
      <div class="doc-card overflow-hidden p-0">
        <table class="w-full text-left">
          <thead>
            <tr class="bg-nexo-dark/[0.03]">
              <th class="px-6 py-4 text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-dark/60">Opción</th>
              <th class="px-6 py-4 text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-dark/60">Descripción</th>
            </tr>
          </thead>
          <tbody>
            {userMenu.map((item, i) => (
              <tr class:list={['border-t border-nexo-dark/5', i % 2 === 0 ? 'bg-white' : 'bg-nexo-dark/[0.015]']}>
                <td class="px-6 py-4 font-bold text-nexo-dark text-sm">{item.option}</td>
                <td class="px-6 py-4 text-nexo-dark/60 text-sm">{item.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
