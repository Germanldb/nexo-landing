---
import DocImage from './DocImage.astro';
import imgAjustes from '../../assets/img-docs/doc-39.png';

interface Props { id?: string; }
const { id } = Astro.props;

const configSections = [
  {
    title: 'Configuración',
    items: [
      { name: 'General', desc: 'Nombre empresa, logo, moneda, zona horaria, datos fiscales.' },
      { name: 'Ubicaciones', desc: 'Zonas geográficas de operación.' },
      { name: 'Sucursales', desc: 'Sedes o puntos de venta.' },
      { name: 'Cloud / Google / Calendario', desc: 'Servicios en la nube, Maps y sync de técnicos.' },
    ],
  },
  {
    title: 'Administración',
    items: [
      { name: 'Gestión personal', desc: 'Operadores, roles y permisos.' },
      { name: 'Portal cliente', desc: 'Qué ve y puede hacer el abonado.' },
      { name: 'Importar clientes', desc: 'Carga masiva desde Excel/CSV.' },
      { name: 'Cambios masivos', desc: 'Modificar facturación u otros datos en lote.' },
      { name: 'Login RADIUS / Backups', desc: 'NAS autorizados y respaldos MikroTik.' },
    ],
  },
  {
    title: 'Facturación y mensajes',
    items: [
      { name: 'Facturación', desc: 'Día de facturación, corte, mora, impuestos, numeración.' },
      { name: 'Pasarelas de pago', desc: 'Bancos y procesadores (API y métodos).' },
      { name: 'Servidor de correo', desc: 'SMTP para emails.' },
      { name: 'Tickets / Zendesk', desc: 'Departamentos e integración externa.' },
      { name: 'Mensajería SMS', desc: 'Proveedor SMS, plantillas y WhatsApp.' },
    ],
  },
  {
    title: 'Herramientas y sistema',
    items: [
      { name: 'Plantillas y mensajes', desc: 'PDF, correos, avisos, textos de facturas.' },
      { name: 'Campos personalizados / VPN', desc: 'Campos extra en ficha y OpenVPN.' },
      { name: 'Base de datos / Crontab / Logs', desc: 'Backup, tareas programadas y auditoría.' },
      { name: 'Servidor / Freeradius / Licencia', desc: 'Estado de servicios, Radius, token y límites.' },
      { name: 'Migrar sistema', desc: 'Migración desde Mikrowisp 5.' },
    ],
  },
];

const procedures = [
  {
    title: 'Crear operador',
    steps: [
      'Gestión personal → Operadores → Nuevo operador',
      'Nombre, usuario, contraseña, email y sucursal',
      'Asigne plantilla de rol o configure el árbol de permisos → Guardar',
    ],
  },
  {
    title: 'Configurar portal',
    steps: [
      'Portal cliente → pestañas General, Reporte pago, Banners',
      'Active/desactive secciones visibles para el abonado',
      'Ajuste textos, logos y colores → Guardar',
    ],
  },
  {
    title: 'Pasarela de pago',
    steps: [
      'Pasarelas → localice el banco (Banesco, Mercantil, BDV, etc.)',
      'Active el switch, complete credenciales API',
      'Método: botón de pago, C2P, pago móvil, transferencia o Debin → pruebe',
    ],
  },
];
---

<section id={id} class="doc-section mb-16">
  <div class="mb-6">
    <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-2 block">Sección 18</span>
    <h2 class="text-3xl md:text-4xl font-extrabold text-nexo-dark tracking-tight">Ajustes generales</h2>
    <p class="text-nexo-dark/50 text-sm mt-2">Configuración del sistema, operadores, portal y pasarelas.</p>
  </div>

  <DocImage
    src={imgAjustes}
    alt="Hub de ajustes generales"
    caption="Entrada a configuración, administración, facturación y sistema."
  />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6 mb-6">
    {configSections.map(section => (
      <div class="doc-card !py-4 !px-5">
        <h3 class="font-bold text-nexo-dark text-sm mb-3">{section.title}</h3>
        <ul class="space-y-2">
          {section.items.map(item => (
            <li class="flex items-start gap-2">
              <span class="w-1 h-1 rounded-full bg-nexo-primary mt-1.5 shrink-0"></span>
              <span class="text-xs text-nexo-dark/60 leading-relaxed"><strong class="text-nexo-dark font-semibold">{item.name}.</strong> {item.desc}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
    {procedures.map(proc => (
      <div class="doc-card !py-4 !px-5">
        <h3 class="font-bold text-nexo-dark text-sm mb-2">{proc.title}</h3>
        <ol class="space-y-2">
          {proc.steps.map((step, i) => (
            <li class="flex items-start gap-2 text-xs text-nexo-dark/65 leading-relaxed">
              <span class="w-4 h-4 rounded bg-nexo-primary text-nexo-dark flex items-center justify-center text-[9px] font-bold shrink-0 mt-0.5">{i + 1}</span>
              {step}
            </li>
          ))}
        </ol>
      </div>
    ))}
  </div>
</section>
