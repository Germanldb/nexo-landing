---
import DocImage from './DocImage.astro';
import imgPanelOverview from '../../assets/img-docs/doc-28.png';

interface Props { id?: string; }
const { id } = Astro.props;
---

<section id={id} class="doc-section mb-16">
  <div class="mb-6">
    <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-2 block">Sección 1</span>
    <h2 class="text-3xl md:text-4xl font-extrabold text-nexo-dark tracking-tight">Introducción</h2>
  </div>

  <div class="space-y-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div>
        <h3 class="text-lg font-bold text-nexo-dark mb-2">¿Qué es Nexo?</h3>
        <p class="text-nexo-dark/70 text-sm leading-relaxed">
          Plataforma para que un ISP administre clientes, facturación, cobros, red, instalaciones, soporte, hotspot y almacén desde un solo panel web.
        </p>
      </div>
      <div>
        <h3 class="text-lg font-bold text-nexo-dark mb-2">¿Para quién es este manual?</h3>
        <p class="text-nexo-dark/70 text-sm leading-relaxed">
          Caja, soporte, instaladores, red y gerencia. No requiere conocimientos de programación.
        </p>
      </div>
    </div>

    <div class="doc-card !p-5">
      <h3 class="text-base font-bold text-nexo-dark mb-3">Dos portales</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div class="bg-nexo-dark/5 rounded-xl p-4">
          <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-1.5 block">Panel Admin</span>
          <p class="text-nexo-dark/70 text-sm leading-relaxed">
            <code class="doc-code-inline">/admin/</code> — personal del ISP.
          </p>
        </div>
        <div class="bg-nexo-dark/5 rounded-xl p-4">
          <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-1.5 block">Portal Cliente</span>
          <p class="text-nexo-dark/70 text-sm leading-relaxed">
            <code class="doc-code-inline">/cliente/</code> — abonados.
          </p>
        </div>
      </div>
    </div>

    <div>
      <h3 class="text-lg font-bold text-nexo-dark mb-2">Cómo funciona el panel</h3>
      <p class="text-nexo-dark/70 text-sm leading-relaxed mb-4">
        Es una SPA: el menú cambia la URL a <code class="doc-code-inline">#ajax/nombre-modulo</code> sin recargar toda la página.
      </p>
      <DocImage
        src={imgPanelOverview}
        alt="Vista general del panel admin de Nexo con menú lateral y dashboard"
        caption="Panel admin: menú lateral, barra superior y contenido central."
      />
    </div>
  </div>
</section>
