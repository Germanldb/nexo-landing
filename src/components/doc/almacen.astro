---
interface Props { id?: string; }
const { id } = Astro.props;

const categories = [
  { title: 'Tipos de productos (Categorías)', menu: 'Almacén → Tipos de productos', desc: 'Categorías de inventario: ONUs, cables, conectores, antenas, etc.' },
  { title: 'Proveedores', menu: 'Almacén → Proveedores', desc: 'Registro de proveedores de equipos y materiales.' },
];

const productTabs = ['Productos (equipos e inventario principal)', 'Accesorios (materiales menores)'];
const filters = ['Estado: Disponible, No disponible, Comodato', 'Categoría'];
---

<section id={id} class="doc-section mb-20">
  <div class="mb-10">
    <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-3 block">Sección 14</span>
    <h2 class="text-3xl md:text-4xl font-extrabold text-nexo-dark tracking-tight">Almacén</h2>
    <p class="text-nexo-dark/50 text-lg mt-4">
      <strong class="text-nexo-dark">Menú:</strong> Almacén (menú expandible) · Control de inventario de equipos y materiales.
    </p>
  </div>

  <div class="space-y-10">
    {categories.map(cat => (
      <div>
        <h3 class="text-xl font-bold text-nexo-dark mb-2">{cat.title}</h3>
        <p class="text-nexo-dark/40 text-sm mb-3"><strong class="text-nexo-dark/60">Menú:</strong> {cat.menu}</p>
        <p class="text-nexo-dark/70 text-base leading-relaxed">{cat.desc}</p>
        <div class="doc-section-divider mt-8"></div>
      </div>
    ))}

    <div>
      <h3 class="text-xl font-bold text-nexo-dark mb-2">Productos</h3>
      <p class="text-nexo-dark/40 text-sm mb-4"><strong class="text-nexo-dark/60">Menú:</strong> Almacén → Productos</p>

      <div class="flex flex-wrap gap-2 mb-5">
        {productTabs.map(tab => (
          <span class="px-3 py-1.5 bg-nexo-dark/5 border border-nexo-dark/10 rounded-lg text-xs font-semibold text-nexo-dark/60">{tab}</span>
        ))}
      </div>

      <h4 class="text-lg font-bold text-nexo-dark mb-4">Ingresar producto al almacén</h4>
      <div class="doc-card mb-6">
        <ol class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-lg bg-nexo-primary text-nexo-dark flex items-center justify-center text-xs font-bold shrink-0 mt-0.5">1</span>
            <span class="text-nexo-dark/70 text-sm">Vaya a Almacén → Productos.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-lg bg-nexo-primary text-nexo-dark flex items-center justify-center text-xs font-bold shrink-0 mt-0.5">2</span>
            <span class="text-nexo-dark/70 text-sm">Haga clic en <strong class="text-nexo-dark">Nuevo Producto</strong>.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-lg bg-nexo-primary text-nexo-dark flex items-center justify-center text-xs font-bold shrink-0 mt-0.5">3</span>
            <div class="text-nexo-dark/70 text-sm">
              <span class="block mb-2">Complete:</span>
              <ul class="list-disc list-inside space-y-1 ml-4 text-xs">
                <li><strong class="text-nexo-dark">Categoría</strong> (tipo de producto).</li>
                <li><strong class="text-nexo-dark">Nombre / descripción.</strong></li>
                <li><strong class="text-nexo-dark">Serial / MAC</strong> (si aplica).</li>
                <li><strong class="text-nexo-dark">Proveedor.</strong></li>
                <li><strong class="text-nexo-dark">Condición:</strong> Nuevo, Comodato o Vendido.</li>
                <li><strong class="text-nexo-dark">Precio de costo</strong> (opcional).</li>
              </ul>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-lg bg-nexo-primary text-nexo-dark flex items-center justify-center text-xs font-bold shrink-0 mt-0.5">4</span>
            <span class="text-nexo-dark/70 text-sm">Guarde. El producto queda en estado <strong class="text-nexo-dark">Disponible</strong>.</span>
          </li>
        </ol>
      </div>

      <h4 class="text-lg font-bold text-nexo-dark mb-4">Asignar producto a instalación</h4>
      <div class="doc-card mb-6">
        <ol class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-lg bg-nexo-primary text-nexo-dark flex items-center justify-center text-xs font-bold shrink-0 mt-0.5">1</span>
            <span class="text-nexo-dark/70 text-sm">Desde Clientes → Instalaciones, abra la orden.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-lg bg-nexo-primary text-nexo-dark flex items-center justify-center text-xs font-bold shrink-0 mt-0.5">2</span>
            <span class="text-nexo-dark/70 text-sm">Haga clic en <strong class="text-nexo-dark">Materiales</strong>.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-lg bg-nexo-primary text-nexo-dark flex items-center justify-center text-xs font-bold shrink-0 mt-0.5">3</span>
            <span class="text-nexo-dark/70 text-sm">Busque el producto por serial o categoría, asigne cantidad y confirme.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-lg bg-nexo-primary text-nexo-dark flex items-center justify-center text-xs font-bold shrink-0 mt-0.5">4</span>
            <span class="text-nexo-dark/70 text-sm">El producto pasa a estado <strong class="text-nexo-dark">Asignado/Vendido</strong>.</span>
          </li>
        </ol>
      </div>

      <div>
        <h4 class="text-sm font-bold text-nexo-dark mb-3">Filtros disponibles</h4>
        <div class="flex flex-wrap gap-2">
          {filters.map(f => (
            <span class="px-3 py-1.5 bg-nexo-primary/10 border border-nexo-primary/30 rounded-lg text-xs font-semibold text-nexo-dark/70">{f}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
