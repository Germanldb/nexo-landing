---
import DocImage from './DocImage.astro';
import imgDashboard from '../../assets/img-docs/doc-28.png';

interface Props { id?: string; }
const { id } = Astro.props;

const elements = [
  { name: 'Saludo', desc: 'Según la hora del operador.' },
  { name: 'Métricas', desc: 'Clientes, facturación y pagos.' },
  { name: 'Gráficos', desc: 'Clientes, ingresos y tráfico.' },
  { name: 'Alertas', desc: 'Desconexiones, mora y licencia.' },
  { name: 'Accesos rápidos', desc: 'Atajos a módulos frecuentes.' },
];
---

<section id={id} class="doc-section mb-16">
  <div class="mb-6">
    <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-2 block">Sección 5</span>
    <h2 class="text-3xl md:text-4xl font-extrabold text-nexo-dark tracking-tight">Dashboard</h2>
    <p class="text-nexo-dark/50 text-sm mt-2">
      Menú: Dashboard · Ruta: <code class="doc-code-inline">/admin/</code> o <code class="doc-code-inline">#ajax/home</code>
    </p>
  </div>

  <div class="space-y-6">
    <div>
      <p class="text-nexo-dark/70 text-base leading-relaxed mb-4">
        Pantalla de inicio: resumen operativo del ISP — clientes, ingresos, tráfico y alertas urgentes.
      </p>
      <DocImage
        src={imgDashboard}
        alt="Dashboard de Nexo con métricas, gráficos y panel de tráfico"
        caption="Dashboard: métricas, gráficos y consumo de red."
      />
    </div>

    <div>
      <h3 class="text-lg font-bold text-nexo-dark mb-4">Elementos principales</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {elements.map((el, i) => (
          <div class="flex items-start gap-3 doc-card !py-3 !px-4">
            <span class="w-6 h-6 rounded-lg bg-nexo-primary text-nexo-dark flex items-center justify-center text-[10px] font-bold shrink-0">{i + 1}</span>
            <div>
              <p class="font-bold text-nexo-dark text-sm">{el.name}</p>
              <p class="text-nexo-dark/55 text-xs mt-0.5">{el.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
