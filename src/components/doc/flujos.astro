---
interface Props { id?: string; }
const { id } = Astro.props;

const flows = [
  {
    title: 'Alta sin instalación',
    steps: [
      'Clientes → Usuarios → Nuevo',
      'Paso 1: datos personales → Paso 2: facturación → Paso 3: servicios',
      'Registrar cliente → factura generada y servicio activo en router',
    ],
  },
  {
    title: 'Alta con instalación',
    steps: [
      'Instalaciones → Nuevo registro → Aceptar (técnico) → materiales',
      'Imprimir hoja → técnico instala → Tareas: En curso → Finalizar',
      'Dar de alta → wizard precargado → cliente activo',
    ],
  },
  {
    title: 'Cobro en caja',
    steps: [
      'Barra superior → $ (Registrar pago) → buscar cliente',
      'Seleccionar factura → forma de pago + monto → Registrar',
      'Si estaba suspendido, el servicio se reactiva → imprimir recibo',
    ],
  },
  {
    title: 'Ciclo de morosidad',
    steps: [
      'Cron: factura el día configurado → avisos SMS/email',
      'Corte el día de corte → cliente suspendido en router/OLT',
      'Cliente paga (caja o portal) → servicio reactivado',
    ],
  },
  {
    title: 'Venta de ficha hotspot',
    steps: [
      'Fichas Hotspot → Nuevo lote → imprimir',
      'Entregar → marcar vendida (al usar o manual)',
      'Consultar en Fichas Hotspot → Ventas',
    ],
  },
  {
    title: 'Atención de soporte',
    steps: [
      'Cliente abre ticket (portal) u operador lo crea',
      'Aparece en Esperando respuesta → operador responde',
      'Cliente recibe notificación → operador cierra al resolver',
    ],
  },
];
---

<section id={id} class="doc-section mb-16">
  <div class="mb-6">
    <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-2 block">Sección 20</span>
    <h2 class="text-3xl md:text-4xl font-extrabold text-nexo-dark tracking-tight">Flujos de trabajo</h2>
    <p class="text-nexo-dark/50 text-sm mt-2">Procesos clave de punta a punta, incluyendo lo que hace el sistema en automático.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {flows.map(flow => (
      <div class="doc-card !py-4 !px-5">
        <h3 class="text-sm font-bold text-nexo-dark mb-3">{flow.title}</h3>
        <div class="space-y-0">
          {flow.steps.map((step, i) => (
            <div class="flex items-start gap-2.5">
              <div class="flex flex-col items-center">
                <span class="w-5 h-5 rounded-full bg-nexo-primary text-nexo-dark flex items-center justify-center text-[10px] font-bold shrink-0">{i + 1}</span>
                {i < flow.steps.length - 1 && <div class="w-0.5 h-3 bg-nexo-dark/10 my-0.5"></div>}
              </div>
              <span class="text-xs text-nexo-dark/65 leading-relaxed pt-0.5">{step}</span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
