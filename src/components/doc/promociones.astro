---
import DocImage from './DocImage.astro';
import imgPromociones from '../../assets/img-docs/doc-24.png';

interface Props { id?: string; }
const { id } = Astro.props;

const fields = [
  'Nombre de la promoción',
  'Tipo: % descuento, monto fijo o meses gratis',
  'Perfiles / planes aplicables',
  'Vigencia (inicio y fin)',
  'Condiciones: nuevos, existentes, etc.',
];
---

<section id={id} class="doc-section mb-16">
  <div class="mb-6">
    <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-nexo-primary mb-2 block">Sección 8</span>
    <h2 class="text-3xl md:text-4xl font-extrabold text-nexo-dark tracking-tight">Promociones</h2>
    <p class="text-nexo-dark/50 text-sm mt-2">Menú: Promociones · Ofertas temporales para atraer o retener clientes.</p>
  </div>

  <div class="space-y-6">
    <p class="text-nexo-dark/70 text-sm leading-relaxed">
      Descuentos, meses gratis o precios especiales. Se aplican al alta o al editar un servicio.
    </p>
    <DocImage
      src={imgPromociones}
      alt="Listado de paquetes promocionales en Nexo"
      caption="Promociones: vigencia, cupo y perfiles."
    />

    <div>
      <h3 class="text-lg font-bold text-nexo-dark mb-3">Crear una promoción</h3>
      <div class="doc-card !py-4 !px-5">
        <ol class="space-y-2.5 mb-4">
          <li class="flex items-start gap-2.5 text-sm text-nexo-dark/70"><span class="w-5 h-5 rounded-md bg-nexo-primary text-nexo-dark flex items-center justify-center text-[10px] font-bold shrink-0">1</span> Promociones → Nueva promoción</li>
          <li class="flex items-start gap-2.5 text-sm text-nexo-dark/70"><span class="w-5 h-5 rounded-md bg-nexo-primary text-nexo-dark flex items-center justify-center text-[10px] font-bold shrink-0">2</span> Complete los campos y guarde</li>
          <li class="flex items-start gap-2.5 text-sm text-nexo-dark/70"><span class="w-5 h-5 rounded-md bg-nexo-primary text-nexo-dark flex items-center justify-center text-[10px] font-bold shrink-0">3</span> Al dar de alta un cliente/servicio, selecciónela</li>
        </ol>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 pt-2 border-t border-nexo-dark/5">
          {fields.map(f => (
            <div class="flex items-start gap-2 text-xs text-nexo-dark/60">
              <span class="w-1 h-1 rounded-full bg-nexo-primary mt-1.5 shrink-0"></span>
              {f}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
