---
const navItems = [
  { name: 'Inicio', href: '/#inicio' },
  { name: 'Recaudación', href: '/#recaudacion' },
  { name: 'Cobertura', href: '/#cobertura' },
  { name: 'Ecosistema', href: '/#modulos' },
  { name: 'FAQ', href: '/#faq' },
];
---

<header id="main-header" class="fixed top-0 w-full z-50 transition-all duration-300 border-b border-transparent">
  <div class="container mx-auto px-6 h-24 flex items-center justify-between">
    <a href="/" class="flex items-center group shrink-0">
      <img src="/logo.png" alt="Nexo Logo" class="nexo-logo h-9 w-auto transition-transform duration-500 group-hover:scale-105" />
    </a>

    <div class="flex items-center gap-5 lg:gap-8">
      <nav class="header-nav-pill hidden lg:flex items-center bg-white/40 backdrop-blur-md px-8 py-3 rounded-full border border-nexo-dark/5 shadow-sm">
        <ul class="flex items-center gap-10">
          {navItems.map(item => (
            <li>
              <a href={item.href} class="text-[13px] font-bold text-nexo-dark/60 hover:text-nexo-primary transition-colors uppercase tracking-[0.1em]">
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <button
        type="button"
        id="nexo-theme-toggle"
        class="nexo-theme-toggle-btn inline-flex"
        title="Modo oscuro"
        aria-label="Alternar modo claro u oscuro"
        aria-pressed="false"
      >
        <i class="fa-solid fa-moon" aria-hidden="true"></i>
      </button>

      <!-- <div class="flex items-center gap-6">
        <a href="/#identidad" class="hidden sm:block text-[13px] font-bold text-nexo-dark/80 hover:text-nexo-primary transition-colors uppercase tracking-[0.1em]">
          Acceso Clientes
        </a>
        <a href="/#contacto" class="header-demo-btn bg-nexo-dark text-white px-8 py-3.5 rounded-xl text-xs font-black uppercase tracking-[0.15em] hover:bg-nexo-primary hover:text-nexo-dark transition-all shadow-xl shadow-nexo-dark/10 active:scale-95">
          Solicitar Demo
        </a>
      </div> -->
    </div>
  </div>
</header>

<script>
  import { initLandingTheme } from '../scripts/landing-theme';

  initLandingTheme();

  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('is-scrolled', 'bg-white/80', 'backdrop-blur-xl', 'border-nexo-dark/5', 'shadow-[0_10px_40px_-15px_rgba(13,46,52,0.08)]');
      header?.querySelector('.container')?.classList.replace('h-24', 'h-20');
    } else {
      header?.classList.remove('is-scrolled', 'bg-white/80', 'backdrop-blur-xl', 'border-nexo-dark/5', 'shadow-[0_10px_40px_-15px_rgba(13,46,52,0.08)]');
      header?.querySelector('.container')?.classList.replace('h-20', 'h-24');
    }
  });
</script>
