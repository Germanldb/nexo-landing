---
import { Image } from 'astro:assets';
import casheaPreview from '../assets/nexo-cashea.png';
import pagoMovilPreview from '../assets/reconciliation-pago-movil.png';
import transferenciaPreview from '../assets/reconciliation-transferencia.png';
import mercadoPagoPreview from '../assets/mercado_pago.png';
import paypalPreview from '../assets/nexo-paypal.png';
import type { ImageMetadata } from 'astro';

type ChannelPreview =
  | { alt: string; asset: ImageMetadata }
  | { alt: string; url: string };

const channelPreviews: Record<string, ChannelPreview> = {
  cashea: {
    asset: casheaPreview,
    alt: 'Pantalla de pago con Cashea integrada en Nexo',
  },
  'pago-movil': {
    asset: pagoMovilPreview,
    alt: 'Formulario de pago móvil en el portal de facturación Nexo',
  },
  transferencia: {
    asset: transferenciaPreview,
    alt: 'Registro de transferencia bancaria en el portal Nexo',
  },
  'pagos-c2p': {
    url: '/reconciliation/c2p.jpg',
    alt: 'Pago móvil C2P con Banco de Venezuela en el portal Nexo',
  },
  'mercado-pago': {
    asset: mercadoPagoPreview,
    alt: 'Pago con Mercado Pago en el portal de facturación Nexo',
  },
  paypal: {
    asset: paypalPreview,
    alt: 'Pago con PayPal en el portal de facturación Nexo',
  },
};

const previewChannelIds = Object.keys(channelPreviews);

const channels = [
  {
    id: 'cashea',
    name: 'Cashea',
    type: 'Financiamiento',
    transactionId: 'Transacción #4892',
    status: 'Validado',
    progressHint: 'Cruzando datos con API bancaria regional...',
    highlightLabel: 'Integración Destacada',
    highlightTitle: 'CASHEA',
    highlightDesc:
      'Habilitamos el pago en cuotas para tus usuarios. Más activaciones, menos facturas vencidas.',
  },
  {
    id: 'pago-movil',
    name: 'Pago Móvil',
    type: 'Inmediato',
    transactionId: 'Pago Móvil #2841',
    status: 'Validado',
    progressHint: 'Conciliando teléfono, cédula y monto con el banco...',
    highlightLabel: 'Canal activo',
    highlightTitle: 'PAGO MÓVIL',
    highlightDesc:
      'El cliente transfiere desde su banco con teléfono, cédula y monto. Conciliación manual o automática según el banco.',
  },
  {
    id: 'transferencia',
    name: 'Transferencia',
    type: 'Manual / automatizada',
    transactionId: 'Transferencia #7103',
    status: 'En revisión',
    progressHint: 'Cruzando referencia bancaria con factura pendiente...',
    highlightLabel: 'Canal activo',
    highlightTitle: 'TRANSFERENCIA',
    highlightDesc:
      'Depósito o transferencia bancaria. Puede conciliarse a mano o con notificación/API del banco.',
  },
  {
    id: 'pagos-c2p',
    name: 'Pagos C2P',
    type: 'Manual / automatizada',
    transactionId: 'C2P #5521',
    status: 'Validado',
    progressHint: 'Verificando pago comercio a persona con el banco...',
    highlightLabel: 'Canal activo',
    highlightTitle: 'PAGOS C2P',
    highlightDesc:
      'Cobro con tarjeta desde la app del banco (comercio a persona). Conciliación manual o automática según la entidad.',
  },
  {
    id: 'mercado-pago',
    name: 'Mercado Pago',
    type: 'Internacional',
    transactionId: 'Mercado Pago #9024',
    status: 'Validado',
    progressHint: 'Sincronizando pasarela regional...',
    highlightLabel: 'Canal activo',
    highlightTitle: 'MERCADO PAGO',
    highlightDesc:
      'Tarjeta, débito y medios locales en LATAM. Ideal para clientes fuera de Venezuela o pagos en moneda extranjera.',
  },
  {
    id: 'paypal',
    name: 'PayPal',
    type: 'Electrónico',
    transactionId: 'PayPal #3318',
    status: 'Validado',
    progressHint: 'Confirmando pago electrónico en pasarela...',
    highlightLabel: 'Canal activo',
    highlightTitle: 'PAYPAL',
    highlightDesc:
      'Cobro con cuenta PayPal o tarjeta internacional (USD/EUR). Para clientes en el exterior o pagos en divisas.',
  },
] as const;

const defaultChannelId = 'cashea';
const defaultHasPreview = previewChannelIds.includes(defaultChannelId);
---

<section id="recaudacion" class="preserve-brand-colors py-32 bg-nexo-dark overflow-hidden relative">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-nexo-primary/5 rounded-full blur-[150px] -mr-64 -mt-64"></div>

    <div class="container mx-auto px-6 relative z-10">
        <div class="flex flex-col lg:flex-row gap-24 items-start">
            
            <div class="lg:w-1/3 gsap-reveal">
                <span class="text-nexo-primary font-bold tracking-[0.2em] uppercase text-[10px] mb-8 block">Finanzas & Logística</span>
                <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-10 tracking-tight leading-tight">
                    Recaudación <br/>
                    y Conciliación <br/>
                    <span class="text-nexo-primary">Blindada.</span>
                </h2>
                <div class="space-y-8">
                    <div class="border-l-2 border-nexo-primary/30 pl-6">
                        <h4 class="text-white font-bold text-lg mb-2">Omnicanalidad Real</h4>
                        <p class="text-white/50 text-sm leading-relaxed">BDV, Bancaribe, Pago Móvil, C2P, Cashea, Mercado Pago, PayPal y más — sin fricción para quien paga ni para quien concilia.</p>
                    </div>
                    <div class="border-l-2 border-nexo-primary/30 pl-6">
                        <h4 class="text-white font-bold text-lg mb-2">Conciliación Bancaria</h4>
                        <p class="text-white/50 text-sm leading-relaxed">Cruce automático con el ecosistema bancario: menos reportes manuales y cierre de ciclo más rápido.</p>
                    </div>
                    <div class="border-l-2 border-nexo-primary/30 pl-6">
                        <h4 class="text-white font-bold text-lg mb-2">Reactivación Instantánea</h4>
                        <p class="text-white/50 text-sm leading-relaxed">Pago validado es igual a servicio activo en milisegundos. Cero intervención humana.</p>
                    </div>
                </div>
            </div>

            <div class="lg:w-2/3 w-full">
                <div class="grid md:grid-cols-2 gap-8 gsap-reveal" id="reconciliation-interactive">
                    
                    <div class="bg-white/5 backdrop-blur-md p-10 rounded-[3rem] border border-white/10 relative group">
                        <div class="absolute top-0 right-0 p-8">
                            <div class="w-12 h-12 bg-nexo-primary/10 rounded-full flex items-center justify-center text-nexo-primary">💳</div>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-8">Canales de Pago</h3>
                        <div class="space-y-4" role="tablist" aria-label="Canales de pago">
                            {channels.map((c) => (
                                <button
                                    type="button"
                                    role="tab"
                                    data-channel-id={c.id}
                                    aria-selected={c.id === defaultChannelId ? 'true' : 'false'}
                                    class:list={[
                                        'recon-channel-btn w-full flex justify-between items-center p-4 rounded-2xl border transition-all text-left cursor-pointer',
                                        c.id === defaultChannelId
                                            ? 'bg-nexo-primary border-nexo-primary text-nexo-dark font-black'
                                            : 'bg-white/5 border-white/5 text-white/70 hover:bg-white/10',
                                    ]}
                                >
                                    <span class="text-sm uppercase tracking-wider">{c.name}</span>
                                    <span class="text-[10px] opacity-60 uppercase font-bold">{c.type}</span>
                                </button>
                            ))}
                        </div>
                        <p class="mt-10 text-[11px] text-white/30 uppercase tracking-[0.2em] text-center">Compatible Multi-País</p>
                    </div>

                    <div class="space-y-8">
                        <div class="bg-nexo-primary p-10 rounded-[3rem] text-nexo-dark group overflow-hidden relative">
                            <div class="absolute -right-4 -bottom-4 w-32 h-32 bg-nexo-dark/10 rounded-full group-hover:scale-120 transition-transform duration-700"></div>
                            <div class="relative z-10">
                                <div id="recon-highlight-label" class="text-[10px] font-black uppercase tracking-[0.2em] mb-4">{channels[0].highlightLabel}</div>
                                <h3 id="recon-highlight-title" class="text-4xl font-black mb-6 italic">{channels[0].highlightTitle}</h3>
                                <p id="recon-highlight-desc" class="text-nexo-dark/70 font-bold leading-snug">
                                    {channels[0].highlightDesc}
                                </p>
                            </div>
                        </div>
                        <div class="bg-gradient-to-br from-nexo-primary/20 to-transparent p-10 rounded-[3rem] border border-nexo-primary/20">
                            <div class="flex items-center gap-4 mb-8">
                                <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center text-nexo-dark font-bold text-xl">🏛️</div>
                                <h3 class="text-xl font-bold text-white">Conciliación Bancaria</h3>
                            </div>
                            <div class="rounded-2xl border border-white/5 overflow-hidden bg-white/95 shadow-inner">
                                {Object.entries(channelPreviews).map(([channelId, preview]) => (
                                    <div
                                        class="recon-preview-panel"
                                        data-preview-for={channelId}
                                        hidden={defaultChannelId !== channelId}
                                    >
                                        {'asset' in preview ? (
                                            <Image
                                                src={preview.asset}
                                                alt={preview.alt}
                                                class="w-full h-auto block"
                                                widths={[320, 480, 640]}
                                                sizes="(max-width: 768px) 100vw, 320px"
                                                loading="lazy"
                                            />
                                        ) : (
                                            <img
                                                src={preview.url}
                                                alt={preview.alt}
                                                class="w-full h-auto block"
                                                loading="lazy"
                                                decoding="async"
                                            />
                                        )}
                                    </div>
                                ))}

                                <div
                                    id="recon-preview-fallback"
                                    class="recon-preview-panel bg-nexo-dark-900/50 p-6"
                                    data-preview-for="fallback"
                                    hidden={defaultHasPreview}
                                >
                                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-white/5">
                                        <span id="recon-transaction-id" class="text-white/40 text-xs">{channels[0].transactionId}</span>
                                        <span id="recon-status" class="text-nexo-primary text-xs font-bold">{channels[0].status}</span>
                                    </div>
                                    <div class="space-y-3">
                                        <div class="h-2 w-full bg-white/5 rounded-full overflow-hidden">
                                            <div class="h-full bg-nexo-primary w-full animate-pulse"></div>
                                        </div>
                                        <p id="recon-progress-hint" class="text-[10px] text-white/30 leading-tight">{channels[0].progressHint}</p>
                                    </div>
                                </div>
                            </div>
                            <p class="mt-8 text-white/50 text-sm leading-relaxed">
                                Nexo automatiza el cuadre de caja de tu ISP integrándose directamente con los núcleos bancarios.
                            </p>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>

<script define:vars={{ channels, defaultChannelId, previewChannelIds }}>
  const channelMap = Object.fromEntries(channels.map((c) => [c.id, c]));

  const activeClasses = ['bg-nexo-primary', 'border-nexo-primary', 'text-nexo-dark', 'font-black'];
  const inactiveClasses = ['bg-white/5', 'border-white/5', 'text-white/70', 'hover:bg-white/10'];

  function setChannelActive(channelId) {
    const data = channelMap[channelId];
    if (!data) return;

    document.querySelectorAll('.recon-channel-btn').forEach((btn) => {
      const isActive = btn.dataset.channelId === channelId;
      btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
      activeClasses.forEach((cls) => btn.classList.toggle(cls, isActive));
      inactiveClasses.forEach((cls) => btn.classList.toggle(cls, !isActive));
      if (isActive) {
        btn.classList.remove('hover:bg-white/10');
      }
    });

    const tx = document.getElementById('recon-transaction-id');
    const status = document.getElementById('recon-status');
    const hint = document.getElementById('recon-progress-hint');
    const label = document.getElementById('recon-highlight-label');
    const title = document.getElementById('recon-highlight-title');
    const highlightDesc = document.getElementById('recon-highlight-desc');

    if (tx) tx.textContent = data.transactionId;
    if (status) status.textContent = data.status;
    if (hint) hint.textContent = data.progressHint;
    if (label) label.textContent = data.highlightLabel;
    if (title) title.textContent = data.highlightTitle;
    if (highlightDesc) highlightDesc.textContent = data.highlightDesc;

    const hasPreview = previewChannelIds.includes(channelId);

    document.querySelectorAll('.recon-preview-panel[data-preview-for]').forEach((panel) => {
      const panelId = panel.dataset.previewFor;
      if (panelId === 'fallback') return;
      panel.hidden = panelId !== channelId;
    });

    const fallbackPreview = document.getElementById('recon-preview-fallback');
    if (fallbackPreview) fallbackPreview.hidden = hasPreview;
  }

  document.querySelectorAll('.recon-channel-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      setChannelActive(btn.dataset.channelId);
    });
  });

  setChannelActive(defaultChannelId);
</script>
